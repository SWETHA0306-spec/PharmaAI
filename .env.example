# Copy this file to ".env" (same folder) and fill in your real values.
# .env is loaded automatically on startup — no need to set these in the
# terminal every time you open a new session.

# Required for the medicine label OCR step (image mode). This is the
# OpenRouter (or any OpenAI-compatible) key used by core/ocr_fixed.py to
# extract text from a medicine strip/label image. OCR never uses Sarvam.
OCR_API_KEY=your_openrouter_key_here

# Required for the Sarvam AI Assistant: turning already-verified medicine
# data into a patient-friendly explanation, translating it, and generating
# voice (TTS). Get your key from the Sarvam AI dashboard. Without this,
# verified medicine information still works — only the AI explanation,
# translation, and voice features are unavailable.
SARVAM_API_KEY=your_sarvam_key_here

# Used to sign login session tokens. Set this to any long random string
# and keep it the same across restarts, otherwise everyone gets logged
# out every time the server restarts. If left unset, a temporary random
# secret is generated at startup (fine for local testing only).
JWT_SECRET=your_random_secret_here

# Maximum total size (in MB) of the audio_cache/ folder that stores
# generated Sarvam voice clips, keyed by medicine + language. Oldest
# (least-recently-used) clips are deleted automatically once this is
# exceeded. Default: 200.
AUDIO_CACHE_MAX_MB=200

